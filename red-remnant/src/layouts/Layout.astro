---
import '../styles/global.css';
import { brand, booking } from '../data/content';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "IOFDigital: Digitalagentur aus Gummersbach",
  description = "IOFDigital ist IT-Systemhaus, Automatisierungspartner und Digitalbüro für den Mittelstand in Gummersbach: Microsoft 365, Power Platform, KI, Design.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brand.name,
  description,
  url: Astro.site?.toString(),
  address: {
    '@type': 'PostalAddress',
    addressLocality: brand.location,
    addressCountry: 'DE',
  },
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} is:inline />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;800;900&family=Playfair+Display:ital,wght@1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <!-- Cal.com booking widget — popup triggered by [data-cal-link] buttons -->
    <script define:vars={{ namespace: booking.namespace }} is:inline>
      (function (C, A, L) {
        let p = function (a, ar) { a.q.push(ar); };
        let d = C.document;
        C.Cal = C.Cal || function () {
          let cal = C.Cal;
          let ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () { p(api, arguments); };
            const ns = ar[1];
            api.q = api.q || [];
            if (typeof ns === "string") {
              cal.ns[ns] = cal.ns[ns] || api;
              p(cal.ns[ns], ar);
              p(cal, ["initNamespace", ns]);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      Cal("init", namespace, { origin: "https://cal.com" });

      Cal.ns[namespace]("ui", {
        theme: "dark",
        hideEventTypeDetails: false,
        layout: "month_view",
        cssVarsPerTheme: {
          dark: {
            "cal-brand": "#3b7dd8",
            "cal-brand-emphasis": "#2f6ec8",
            "cal-brand-text": "#f8fbff",
            "cal-bg": "#0a0c12",
            "cal-bg-emphasis": "#11141d",
            "cal-border": "rgba(255,255,255,0.16)",
            "radius": "16px",
          },
        },
      });
    </script>
  </head>

  <body>

    <slot />

    <script>
      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.10 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      // Nav glass on scroll
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        if (!nav) return;
        nav.style.background = window.scrollY > 60
          ? 'rgba(40, 100, 170, 0.30)'
          : 'rgba(255, 255, 255, 0.14)';
      }, { passive: true });

      // Button ripple
      document.querySelectorAll('button, a[data-btn]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const rect = (btn as HTMLElement).getBoundingClientRect();
          const me = e as MouseEvent;
          const size = Math.max(rect.width, rect.height) * 2;
          const r = document.createElement('span');
          r.style.cssText = `position:absolute;border-radius:50%;pointer-events:none;width:${size}px;height:${size}px;left:${me.clientX - rect.left - size / 2}px;top:${me.clientY - rect.top - size / 2}px;background:rgba(255,255,255,0.20);animation:ripple 0.55s cubic-bezier(0.16,1,0.3,1) forwards;`;
          (btn as HTMLElement).style.position = 'relative';
          (btn as HTMLElement).style.overflow = 'hidden';
          btn.appendChild(r);
          setTimeout(() => r.remove(), 600);
        });
      });
    </script>
  </body>
</html>
