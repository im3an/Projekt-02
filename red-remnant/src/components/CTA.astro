---
import { finalCta, booking } from "../data/content";
---

<section
    id="cta-outer"
    class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-void-black"
>
    <a id="kontakt" class="absolute" style="top: -7rem;"></a>

    <!-- Ambient orb -->
    <div
        class="absolute pointer-events-none"
        style="width:1100px; height:700px; top:50%; left:50%; transform:translate(-50%,-55%); background:radial-gradient(ellipse, rgba(59,125,216,0.07) 0%, transparent 65%); filter:blur(80px);"
    >
    </div>

    <!-- Noise grain overlay -->
    <div
        class="absolute inset-0 pointer-events-none opacity-[0.025]"
        style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22200%22 height=%22200%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>'); background-size:200px 200px;"
    >
    </div>

    <div class="relative max-w-[1200px] mx-auto w-full px-8 md:px-16 py-32">
        <!-- Giant headline -->
        <div class="reveal mb-12">
            <h2
                class="font-black text-white leading-[0.95] tracking-[-4px]"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(64px,11vw,152px);"
            >
                {finalCta.headline}<br />
                <em
                    class="block"
                    style="font-family:'Playfair Display',serif; font-style:italic; font-weight:500; color:rgba(248,251,255,0.75); font-size:0.92em; tracking-[-2px];"
                    >{finalCta.headlineItalic}</em
                >
            </h2>
        </div>

        <!-- Body + CTA row -->
        <div
            class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-14"
        >
            <!-- Body copy + ghost link -->
            <div class="max-w-[400px]">
                <p
                    class="text-[17px] leading-[1.7]"
                    style="color:rgba(248,251,255,0.55);"
                >
                    {finalCta.body}
                </p>
                <div class="flex flex-wrap items-center gap-x-6 gap-y-3 mt-8">
                    {finalCta.links.map((link) => (
                        <a
                            href={link.href}
                            target="_blank"
                            rel="noopener"
                            class="cta-ghost-link inline-flex items-center gap-2 text-[14px] font-semibold no-underline group"
                            style="color:rgba(248,251,255,0.45);"
                        >
                            {link.label}
                            <svg
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
                                ><line x1="7" y1="17" x2="17" y2="7"></line><polyline
                                    points="7 7 17 7 17 17"></polyline></svg
                            >
                        </a>
                    ))}
                </div>
            </div>

            <!-- Giant primary button -->
            <div class="flex-shrink-0">
                <a
                    href={finalCta.primary.href}
                    data-cal-link={booking.calLink}
                    data-cal-namespace={booking.namespace}
                    class="cta-giant-btn relative inline-flex items-center gap-4 no-underline group"
                    style="background:#3b7dd8; border:1px solid rgba(255,255,255,0.20); border-radius:20px; padding:28px 52px; box-shadow:0 8px 48px rgba(30,80,180,0.50), 0 0 0 0 rgba(59,125,216,0.4);"
                >
                    <span
                        class="text-white font-black leading-none"
                        style="font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(20px,2.2vw,28px); letter-spacing:-0.5px;"
                        >{finalCta.primary.label}</span
                    >
                    <span
                        class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 transition-transform duration-300 group-hover:translate-x-1"
                        style="background:rgba(255,255,255,0.18);"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="white"
                            stroke-width="2.2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="5" y1="12" x2="19" y2="12"
                            ></line><polyline points="12 5 19 12 12 19"
                            ></polyline></svg
                        >
                    </span>
                    <!-- Shimmer -->
                    <span
                        class="cta-shimmer absolute inset-0 rounded-[19px] overflow-hidden pointer-events-none"
                    >
                        <span
                            class="cta-shimmer-beam absolute top-0 h-full w-1/3 pointer-events-none"
                            style="background:linear-gradient(90deg, transparent, rgba(255,255,255,0.13), transparent); transform:skewX(-20deg) translateX(-200%);"
                        ></span>
                    </span>
                </a>
            </div>
        </div>

        <!-- Bottom rule + location -->
        <div
            class="reveal flex items-center justify-between mt-20 pt-8"
            style="border-top:1px solid rgba(255,255,255,0.08);"
        >
            <div
                class="flex items-center gap-2 text-[13px]"
                style="color:rgba(248,251,255,0.50);"
            >
                <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
                {finalCta.location}
            </div>
            <!-- Availability dot -->
            <div
                class="flex items-center gap-2 text-[12px]"
                style="color:rgba(248,251,255,0.50);"
            >
                <span
                    class="w-1.5 h-1.5 rounded-full"
                    style="background:#4ade80; box-shadow:0 0 6px #4ade80;"
                ></span>
                Verfügbar
            </div>
        </div>
    </div>
</section>

<style>
    .cta-ghost-link:hover,
    .cta-ghost-link:focus-visible {
        color: rgba(248, 251, 255, 0.85) !important;
    }
    .cta-ghost-link:focus-visible {
        outline: 2px solid rgba(255, 255, 255, 0.6);
        outline-offset: 3px;
        border-radius: 2px;
    }
    .cta-giant-btn {
        transition:
            transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
            box-shadow 0.25s ease;
    }
    .cta-giant-btn:hover {
        transform: translateY(-3px);
        box-shadow:
            0 16px 64px rgba(30, 80, 180, 0.65),
            0 0 0 6px rgba(59, 125, 216, 0.15) !important;
    }
    .cta-giant-btn:hover .cta-shimmer-beam {
        animation: shimmer 0.6s ease forwards;
    }
    @keyframes shimmer {
        from {
            transform: skewX(-20deg) translateX(-200%);
        }
        to {
            transform: skewX(-20deg) translateX(400%);
        }
    }
</style>
