---
import { googleReviews } from '../data/content';

const fullStars = Math.round(googleReviews.avgRating);
---

<section id="bewertungen" class="px-8 md:px-12 py-28 scroll-mt-28 overflow-hidden">
  <div class="max-w-[980px] mx-auto">
    <!-- Header -->
    <div class="reveal text-center max-w-[640px] mx-auto mb-12">
      <span class="text-[12px] font-bold tracking-[2px] uppercase block mb-5" style="color: rgba(248,251,255,0.50);">{googleReviews.label}</span>
      <h2 class="text-white font-extrabold leading-[1.08] tracking-[-1.5px]" style="font-size: clamp(34px, 4vw, 54px);">
        {googleReviews.headline} <em class="font-['Playfair_Display'] italic font-medium tracking-[-0.5px]">{googleReviews.headlineItalic}</em>
      </h2>

      <!-- Aggregate rating row -->
      <div class="inline-flex items-center gap-3 mt-7 px-5 py-3 rounded-full" style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.16);">
        <svg width="20" height="20" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
          <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
          <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24s.85 6.91 2.34 9.88l7.35-5.7z"/>
          <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
        </svg>
        <span class="text-[18px] font-black text-white leading-none">{googleReviews.avgRating.toFixed(1)}</span>
        <span class="flex gap-0.5" aria-hidden="true">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill={i < fullStars ? 'rgba(255,255,255,0.92)' : 'rgba(255,255,255,0.20)'} stroke="none">
              <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/>
            </svg>
          ))}
        </span>
        <span class="text-[13px]" style="color: rgba(248,251,255,0.55);">{googleReviews.totalReviews} Bewertungen</span>
      </div>
    </div>

    <!-- Carousel -->
    <div id="reviews-slider" class="reveal reviews-motion-only relative">
      <div class="overflow-hidden">
        <div id="reviews-track" class="flex" style="transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);">
          {googleReviews.items.map((r) => (
            <div class="w-full flex-shrink-0 px-1.5">
              <div
                class="rounded-[24px] px-8 md:px-12 py-10 md:py-12 h-full flex flex-col"
                style="background: rgba(255,255,255,0.09); backdrop-filter: blur(24px) saturate(1.4); -webkit-backdrop-filter: blur(24px) saturate(1.4); border: 1px solid rgba(255,255,255,0.18); box-shadow: 0 24px 60px -24px rgba(10,40,80,0.45);"
              >
                <!-- Stars -->
                <div class="flex gap-1 mb-5">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill={i < r.rating ? 'rgba(255,255,255,0.92)' : 'rgba(255,255,255,0.18)'} stroke="none">
                      <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/>
                    </svg>
                  ))}
                </div>

                <!-- Quote -->
                <p class="text-white leading-[1.6] mb-8" style="font-size: clamp(16px, 1.8vw, 19px);">
                  {r.text}
                </p>

                <!-- Author -->
                <div class="mt-auto flex items-center justify-between gap-4 pt-6" style="border-top: 1px solid rgba(255,255,255,0.12);">
                  <div class="text-[14.5px] font-bold text-white">{r.authorAttribution.displayName}</div>
                  <div class="text-[12.5px]" style="color: rgba(248,251,255,0.50);">{r.relativePublishTimeDescription}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Controls -->
      <div class="flex items-center justify-center gap-6 mt-8">
        <button
          id="reviews-prev" aria-label="Vorherige"
          class="reviews-arrow w-11 h-11 rounded-full flex items-center justify-center text-white cursor-pointer transition-all duration-200"
          style="background: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.22);"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="flex items-center gap-2">
          {googleReviews.items.map((_, i) => (
            <button class="reviews-dot rounded-full transition-all duration-400 cursor-pointer" data-i={i} aria-label={`Bewertung ${i + 1}`}
              style={`height: 6px; width: ${i === 0 ? '24px' : '6px'}; background: ${i === 0 ? 'rgba(255,255,255,0.90)' : 'rgba(255,255,255,0.28)'}; border: none; border-radius: 9px;`}></button>
          ))}
        </div>

        <button
          id="reviews-next" aria-label="Nächste"
          class="reviews-arrow w-11 h-11 rounded-full flex items-center justify-center text-white cursor-pointer transition-all duration-200"
          style="background: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.22);"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <!-- Static fallback grid for prefers-reduced-motion -->
    <div class="reviews-static hidden grid-cols-1 md:grid-cols-2 gap-5">
      {googleReviews.items.map((r) => (
        <div
          class="rounded-[24px] p-8 flex flex-col"
          style="background: rgba(255,255,255,0.09); border: 1px solid rgba(255,255,255,0.18);"
        >
          <div class="flex gap-1 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill={i < r.rating ? 'rgba(255,255,255,0.92)' : 'rgba(255,255,255,0.18)'} stroke="none">
                <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/>
              </svg>
            ))}
          </div>
          <p class="text-[15px] leading-[1.6] text-white mb-6">{r.text}</p>
          <div class="mt-auto flex items-center justify-between gap-4 pt-5" style="border-top: 1px solid rgba(255,255,255,0.12);">
            <div class="text-[14px] font-bold text-white">{r.authorAttribution.displayName}</div>
            <div class="text-[12px]" style="color: rgba(248,251,255,0.50);">{r.relativePublishTimeDescription}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews-arrow:hover,
  .reviews-arrow:focus-visible {
    background: rgba(255, 255, 255, 0.20);
  }
  .reviews-arrow:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.7);
    outline-offset: 2px;
  }
  .reviews-dot:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.7);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .reviews-motion-only { display: none !important; }
    .reviews-static { display: grid; }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const track = document.getElementById('reviews-track') as HTMLElement | null;
    const slider = document.getElementById('reviews-slider');
    if (track && slider) {
      const dots  = Array.from(document.querySelectorAll<HTMLElement>('.reviews-dot'));
      const total = track.children.length;
      let cur = 0;
      let timer: ReturnType<typeof setInterval>;
      let tabVisible = true;

      const render = () => {
        track.style.transform = `translateX(-${cur * 100}%)`;
        dots.forEach((d, i) => {
          d.style.width      = i === cur ? '24px' : '6px';
          d.style.background = i === cur ? 'rgba(255,255,255,0.90)' : 'rgba(255,255,255,0.28)';
        });
      };
      const go = (i: number) => { cur = (i + total) % total; render(); };

      document.getElementById('reviews-next')?.addEventListener('click', () => { go(cur + 1); reset(); });
      document.getElementById('reviews-prev')?.addEventListener('click', () => { go(cur - 1); reset(); });
      dots.forEach((d) => d.addEventListener('click', () => { go(Number(d.dataset.i)); reset(); }));

      const start = () => { clearInterval(timer); if (tabVisible) timer = setInterval(() => go(cur + 1), 6000); };
      const reset = () => start();

      slider.addEventListener('mouseenter', () => clearInterval(timer));
      slider.addEventListener('mouseleave', start);

      document.addEventListener('visibilitychange', () => {
        tabVisible = document.visibilityState === 'visible';
        if (tabVisible) start(); else clearInterval(timer);
      });

      // Pause entirely while scrolled off-screen
      const io = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) start();
        else clearInterval(timer);
      }, { threshold: 0.2 });
      io.observe(slider);

      render();
    }
  }
</script>
