---
import { vision } from '../data/content';
---

<section class="max-w-[1160px] mx-auto px-8 md:px-12 py-28">
  <!-- Header -->
  <div class="reveal max-w-[720px] mb-16">
    <span class="text-[12px] font-bold tracking-[2px] uppercase block mb-5" style="color: rgba(248,251,255,0.50);">{vision.label}</span>
    <h2 class="text-white font-extrabold leading-[1.08] tracking-[-1.5px]" style="font-size: clamp(34px, 4vw, 54px);">
      {vision.headline} <em class="font-['Playfair_Display'] italic font-medium tracking-[-0.5px]">{vision.headlineItalic}</em>
    </h2>
    <p class="text-[16.5px] leading-[1.70] max-w-[600px] mt-4" style="color: rgba(248,251,255,0.62);">{vision.body}</p>
  </div>

  <!-- Three principles -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-px rounded-[20px] overflow-hidden reveal" style="background: rgba(255,255,255,0.12);">
    {vision.points.map((p) => (
      <div class="p-9 md:p-10" style="background: rgba(255,255,255,0.07);">
        <div class="text-[13px] font-black tracking-[1px] mb-6" style="font-family: 'Plus Jakarta Sans', sans-serif; color: rgba(248,251,255,0.40);">{p.num}</div>
        <h3 class="text-[18px] font-extrabold text-white leading-[1.25] tracking-[-0.3px] mb-3">{p.title}</h3>
        <p class="text-[14.5px] leading-[1.65]" style="color: rgba(248,251,255,0.62);">{p.text}</p>
      </div>
    ))}
  </div>
</section>
